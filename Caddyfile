# ============================================================
# 渡屿AI Gateway — Caddy 反向代理配置（生产环境）
# 自动 HTTPS（Let's Encrypt）
# 翻译自 nginx/api.conf + nginx/register.conf
# ============================================================

# 全局配置
{
	# 邮箱用于 Let's Encrypt 证书注册通知
	email admin@{$MAIN_DOMAIN}
	# 启用 HTTP/3
	servers {
		protocols h1 h2 h2c h3
	}
}

# ==================== 主域名站点 ====================
{$MAIN_DOMAIN} {

	# ---------- 安全响应头 ----------
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# 请求体大小限制 100MB
	request_body {
		max_size 100MB
	}

	# ---------- Chat UI 静态文件 ----------
	# /chat → 302 重定向到 /chat/
	redir /chat /chat/ 302

	handle_path /chat/* {
		root * /srv/chat-ui
		file_server
		try_files {path} {path}/ /index.html
	}

	# ---------- Resin 代理池管理面板 ----------
	handle_path /resin/* {
		reverse_proxy resin:2260 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			flush_interval -1
		}
	}

	# ---------- Antigravity 账号管理面板 ----------
	handle_path /antigravity/* {
		reverse_proxy antigravity-manager:8045 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			flush_interval -1
		}
	}

	# ---------- SSE 流式传输优化（/v1/responses） ----------
	handle /v1/responses* {
		reverse_proxy new-api:3000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up Connection ""
			flush_interval -1
			transport http {
				read_timeout 600s
				write_timeout 600s
			}
		}
	}

	# ---------- New API 首页（注入 Chat UI 入口） ----------
	# 精确匹配 / 路径，注入 home-entry.js 脚本
	handle / {
		reverse_proxy new-api:3000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up Connection ""
			transport http {
				read_timeout 600s
				write_timeout 600s
			}
		}
		replace </body> "<script src=\"/chat/home-entry.js?v=20260317-utf8-2\"></script></body>"
	}

	# ---------- 默认：反代到 New API（SSE 优化） ----------
	handle {
		reverse_proxy new-api:3000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up Connection ""
			flush_interval -1
			transport http {
				read_timeout 600s
				write_timeout 600s
			}
		}
	}
}

# ==================== 注册域名站点 ====================
# 仅在 REGISTER_DOMAIN 环境变量非空时生效
{$REGISTER_DOMAIN} {

	# ---------- 安全响应头 ----------
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# 请求体大小限制 10MB
	request_body {
		max_size 10MB
	}

	# ---------- WebSocket 支持（实时日志推送） ----------
	handle /ws/* {
		reverse_proxy gpt-register:9005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
			flush_interval -1
			transport http {
				read_timeout 600s
				write_timeout 600s
			}
		}
	}

	# ---------- 默认：反代到 gpt-register ----------
	handle {
		reverse_proxy gpt-register:9005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up Connection ""
			flush_interval -1
			transport http {
				read_timeout 600s
				write_timeout 600s
			}
		}
	}
}
