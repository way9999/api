# ============================================================
# cursor-auto-register 本地运行配置（Windows + Edge 浏览器）
# 用途：在 Windows 上直接运行，无需 Docker
# 使用方式：
#   1. 将此文件复制到 tools/cursor-auto-register/.env
#   2. 修改邮箱配置（EMAIL_DOMAINS 和 EMAIL_USERNAME）
#   3. cd tools/cursor-auto-register
#   4. pip install -r requirements.txt
#   5. python api.py
#   6. 浏览器打开 http://127.0.0.1:8000
# ============================================================

# ===== 浏览器配置 =====
# 使用 Edge 浏览器（Windows 自带）
BROWSER_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
# 设为 False 可以看到浏览器操作过程（调试用）
BROWSER_HEADLESS=False
# 动态 User-Agent 池
DYNAMIC_USERAGENT=True

# ===== 邮箱配置 =====
EMAIL_TYPE=tempemail

# --- 模式 A: 全自动（需要域名 + Cloudflare Email Routing）---
# 步骤：
#   1. 在 Cloudflare 添加你的域名
#   2. 开启 Email Routing
#   3. 设置 Catch-all 规则 → 转发到 your_username@tempmail.plus
#   4. 在 tempmail.plus 注册并确认转发
# 然后填写以下配置：
EMAIL_DOMAINS=your-domain.com
EMAIL_USERNAME=your_tempmail_username
EMAIL_PIN=
EMAIL_CODE_TYPE=API

# --- 模式 B: 半自动（无需域名）---
# 取消下行注释，使用 Web 页面手动输入验证码
# EMAIL_CODE_TYPE=WEB
# 流程：
#   1. 在 Web 面板点击"自定义注册"
#   2. 使用任意临时邮箱（如 guerrillamail.com）
#   3. 在该邮箱查看验证码
#   4. 在 Web 面板"待验证"页面输入验证码
#   5. 系统自动完成后续注册流程

# ===== 账号管理 =====
MAX_ACCOUNTS=10

# ===== API 服务 =====
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=True
API_WORKERS=1

# ===== 数据库 =====
DATABASE_URL=sqlite+aiosqlite:///./accounts.db
