# ============================================
# API 中转站环境变量配置
# 复制此文件为 .env 并修改对应值
# ============================================

# --- 基础配置 ---
# 你的域名，用于 SSL 证书签发
DOMAIN=api.example.com

# --- MySQL 配置 ---
# MySQL root 用户密码（请使用强密码）
MYSQL_ROOT_PASSWORD=your_mysql_password_here
# MySQL 数据库名称
MYSQL_DATABASE=newapi

# --- New API 配置 ---
# 数据库连接字符串（引用上方 MySQL 密码，一般无需修改格式）
SQL_DSN=root:${MYSQL_ROOT_PASSWORD}@tcp(mysql:3306)/newapi
# Redis 连接字符串（Docker 内部网络，一般无需修改）
REDIS_CONN_STRING=redis://redis:6379
# 会话加密密钥（请随机生成一段字符串）
SESSION_SECRET=your_session_secret_here
# 初始 root 用户 API Token（用于首次通过 API 管理系统）
INITIAL_ROOT_TOKEN=your_root_token_here
# New API 管理后台初始密码（首次登录后请立即修改）
INITIAL_ROOT_PASSWORD=admin123456

# --- Antigravity Manager 配置 ---
# Antigravity 多账号管理代理（覆盖 Claude + Gemini 模型）
# API_KEY: 中转请求鉴权密钥（格式 sk-xxx）
ANTIGRAVITY_API_KEY=sk-your_antigravity_key_here
# WEB_PASSWORD: Web 管理后台密码（留空则使用 API_KEY）
ANTIGRAVITY_WEB_PASSWORD=

# --- CLIProxyAPI 配置 ---
# CLIProxyAPI 通过 config.yaml 配置，见 config/cliproxyapi/config.yaml

# --- Cursor API 配置 ---
# Cursor IDE 逆向（wisdgod/cursor-api）
# AUTH_TOKEN: 中转请求鉴权密钥
# Cursor 账号的 WorkosCursorSessionToken 通过 /tokens API 或 Web 管理后台添加
CURSOR_API_AUTH_TOKEN=your_cursor_api_auth_token_here

# --- Kiro2API 配置 ---
# Amazon Kiro IDE 逆向（caidaoli/kiro2api）
# 令牌池配置见 config/kiro2api/auth_config.json
# KIRO2API_KEY: 下游客户端访问密钥
KIRO2API_KEY=your_kiro2api_key_here

# --- KiroCLI2API 配置 ---
# Amazon Kiro CLI 逆向（HenryXiaoYang/kirocli2api）
# 基于 Kiro CLI 的 OIDC Refresh Token，走 Amazon Q 后端
# 账号池配置见 config/kirocli2api/accounts.csv
# KIROCLI2API_KEY: 下游客户端访问密钥
KIROCLI2API_KEY=sk-your_kirocli2api_key_here
# 同时激活的令牌数量
KIROCLI2API_ACTIVE_TOKEN_COUNT=5

# --- GPT 注册机配置 ---
# OpenAI 账号自动注册（注册完自动注入 CLIProxyAPI）
# 代理地址（需要非 CN/HK 的出口 IP）
GPT_REGISTER_PROXY=http://resin:2260
# 运行模式: dashboard(Web面板) | register(HTTP注册) | browser(浏览器自动化) | inject(仅注入) | watch(监控注入)
GPT_REGISTER_MODE=dashboard
# 设置为 1 则只跑一轮，留空则持续循环
GPT_REGISTER_ONCE=
# Dashboard 访问密码（留空则无需密码）
GPT_REGISTER_DASHBOARD_PWD=
# 允许的出口地区（逗号分隔，如 US,JP,SG，留空则不限制）
# OpenAI 不支持: CN,HK,TW,RU,IR,KP 等
GPT_REGISTER_ALLOWED_REGIONS=US,JP,KR,DE,GB
# Dashboard 启动注册时使用的引擎: http(curl_cffi API) | browser(Playwright+LLM)
GPT_REGISTER_REG_MODE=browser
# LLM 配置（浏览器自动化模式需要，通过 new-api 网关调用）
GPT_REGISTER_LLM_BASE_URL=http://new-api:3000/v1
GPT_REGISTER_LLM_API_KEY=
GPT_REGISTER_LLM_MODEL=gpt-4o

# --- Cursor 自动注册配置 ---
# cursor-auto-register 自动注册 + Token 管理服务
# 最大同时激活的账号数量
CURSOR_REGISTER_MAX_ACCOUNTS=10
# 邮箱域名（需配置 Cloudflare Email Routing）
# CURSOR_REGISTER_EMAIL_DOMAIN=your-domain.com
# tempmail.plus 用户名
# CURSOR_REGISTER_EMAIL_USER=your_tempmail_username

# --- Copilot API 配置 ---
# GitHub Copilot 逆向（ericc-ch/copilot-api）
# GH_TOKEN: GitHub OAuth Token
# 获取方式: npx copilot-api@latest auth --show-token
COPILOT_GH_TOKEN=your_github_oauth_token_here

# --- WARP 代理配置 ---
# Cloudflare WARP SOCKS5 代理，为逆向服务提供干净出站 IP
# 可选：填入 WARP+ 许可证密钥获得更好的速度和 IP 质量
WARP_LICENSE_KEY=

# --- 可选：通知配置 ---
# 用于接收系统告警或通知的 Webhook 地址
# WEBHOOK_URL=https://your-webhook-url
